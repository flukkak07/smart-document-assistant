# --- SMART DOCUMENT ASSISTANT - CLOUD CONFIG ---
# Copy ไฟล์นี้แล้วเปลี่ยนชื่อเป็น .env

# 1. AI Models (Groq API)
GROQ_API_KEY=your_groq_api_key_here

# 2. Database (Neo4j AuraDB)
# ตัวอย่าง URI: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://your_instance_id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# 3. Embeddings (HuggingFace Inference API)
# รับ Token ได้จาก https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your_huggingface_api_token_here
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# 4. App Config
PORT=8000
BACKEND_URL=http://localhost:8000
