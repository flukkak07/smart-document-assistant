# ตั้งค่าคีย์และรหัสผ่านต่างๆ สำหรับใช้ในระบบ
# ให้ทำการ Copy ไฟล์นี้ และเปลี่ยนชื่อเป็น .env ก่อนการรันจริง

# 1. API Keys สำหรับใช้โมเดลออนไลน์
GROQ_API_KEY=your_groq_api_key_here

# 2. การเชื่อมต่อ Neo4j (Knowledge Graph Database)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# 3. ตั้งค่าสำหรับ Ollama (ใช้กรณีรันโมเดล Local)
# หากคุณใช้ Ollama ผ่าน Docker หรือบนเครื่องอื่น อาจต้องเปลี่ยน URL
OLLAMA_BASE_URL=http://localhost:11434

# 4. ตั้งค่าระบบอ่านรูปภาพ (OCR) สำหรับไฟล์แสกนภาษาไทยบน Windows
# หากลงโปรแกรม Tesseract แล้วไม่ได้ตั้งค่า Environment Variable ให้ใส่พาทตรงนี้
TESSERACT_CMD_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
